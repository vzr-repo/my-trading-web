---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Trading Dashboard"
  meta_title="Trading Dashboard | Jakub Vozar"
  description="Backtest SMA crossover strategie na EURUSD 1H datech za rok 2025."
>
  <section class="section-sm">
    <div class="container">
      <h1 class="h2 mb-4">Trading Dashboard</h1>
      <p class="mb-8 text-light">
        Backtest SMA crossover strategie na EURUSD 1H datech za rok 2025.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <iframe
          src="/charts/EquityCurve.html"
          style="width: 100%; height: 450px; border: 1px solid #3E3E3E; border-radius: 8px;"
        ></iframe>
        <iframe
          src="/charts/Drawdown.html"
          style="width: 100%; height: 450px; border: 1px solid #3E3E3E; border-radius: 8px;"
        ></iframe>
        <iframe
          src="/charts/Trades.html"
          style="width: 100%; height: 450px; border: 1px solid #3E3E3E; border-radius: 8px;"
        ></iframe>
        <iframe
          src="/charts/MonthlyPnL.html"
          style="width: 100%; height: 450px; border: 1px solid #3E3E3E; border-radius: 8px;"
        ></iframe>
      </div>
    </div>
  </section>
</Base>