<html lang="cs">
  <head>
    <meta charset="utf-8" />
	<title>Jakub Vozar | Data Engineer</title>
	<style>
  body {
    font-family: sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    color: #1a1a1a;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0;
  }

  h2 {
    font-size: 1.2rem;
    color: #666;
    font-weight: normal;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  p {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 16px;
  }

	.dashboard-preview {
  margin-top: 60px;
}

.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 24px;
}

.charts-grid iframe {
  width: 100%;
  height: 400px;
  border: 1px solid #eee;
  border-radius: 8px;
}

</style>
